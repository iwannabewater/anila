{
  "model": {
    "context_length": 128,
    "n_layer": 2,
    "n_head": 4,
    "n_kv_head": 2,
    "n_embd": 128,
    "dropout": 0.0
  },
  "train": {
    "objective": "dpo",
    "init_from": "runs/sft-smoke/checkpoints/latest.pt",
    "dataset_path": "examples/tiny_preferences.jsonl",
    "tokenizer_path": "runs/tokenizer",
    "out_dir": "runs/dpo-smoke",
    "batch_size": 2,
    "max_steps": 10,
    "learning_rate": 0.0003,
    "weight_decay": 0.1,
    "warmup_steps": 2,
    "eval_interval": 5,
    "save_interval": 5,
    "log_interval": 5,
    "device": "auto",
    "dtype": "auto",
    "compile": false
  },
  "dpo": {
    "beta": 0.1
  }
}
