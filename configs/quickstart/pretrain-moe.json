{
  "model": {
    "context_length": 64,
    "n_layer": 2,
    "n_head": 4,
    "n_kv_head": 2,
    "n_embd": 128,
    "dropout": 0.0,
    "moe_num_experts": 4,
    "moe_top_k": 1,
    "moe_intermediate_size": 128,
    "moe_aux_loss_coef": 0.001
  },
  "train": {
    "objective": "pretrain",
    "dataset_path": "examples/tiny_corpus.txt",
    "tokenizer_path": "runs/tokenizer",
    "out_dir": "runs/quickstart/pretrain-moe",
    "batch_size": 2,
    "max_steps": 10,
    "learning_rate": 0.0006,
    "weight_decay": 0.1,
    "warmup_steps": 2,
    "eval_interval": 5,
    "save_interval": 5,
    "log_interval": 5,
    "device": "auto",
    "dtype": "auto",
    "compile": false
  },
  "data": {
    "pretrain_mode": "packed"
  }
}
