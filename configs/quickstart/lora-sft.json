{
  "model": {
    "context_length": 128,
    "n_layer": 2,
    "n_head": 4,
    "n_kv_head": 2,
    "n_embd": 128,
    "dropout": 0.0
  },
  "train": {
    "objective": "sft",
    "init_from": "runs/quickstart/pretrain/checkpoints/latest.pt",
    "dataset_path": "examples/tiny_sft.jsonl",
    "tokenizer_path": "runs/tokenizer",
    "out_dir": "runs/quickstart/lora-sft",
    "batch_size": 2,
    "max_steps": 10,
    "learning_rate": 0.001,
    "weight_decay": 0.0,
    "warmup_steps": 2,
    "eval_interval": 5,
    "save_interval": 5,
    "log_interval": 5,
    "device": "auto",
    "dtype": "auto",
    "compile": false
  },
  "lora": {
    "enabled": true,
    "rank": 4,
    "alpha": 8.0,
    "dropout": 0.0,
    "target_modules": ["q_proj", "v_proj"],
    "train_base": false,
    "train_bias": false,
    "save_adapter": true
  },
  "sft": {
    "format": "auto"
  }
}
