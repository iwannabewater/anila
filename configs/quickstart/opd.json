{
  "model": {
    "context_length": 128,
    "n_layer": 2,
    "n_head": 4,
    "n_kv_head": 2,
    "n_embd": 128,
    "dropout": 0.0
  },
  "train": {
    "objective": "opd",
    "init_from": "runs/quickstart/pretrain/checkpoints/latest.pt",
    "dataset_path": "examples/tiny_opd_prompts.jsonl",
    "tokenizer_path": "runs/tokenizer",
    "out_dir": "runs/quickstart/opd",
    "batch_size": 1,
    "max_steps": 10,
    "learning_rate": 0.0003,
    "weight_decay": 0.1,
    "warmup_steps": 2,
    "eval_interval": 5,
    "save_interval": 5,
    "log_interval": 5,
    "device": "auto",
    "dtype": "auto",
    "compile": false
  },
  "opd": {
    "teacher_checkpoint": "runs/quickstart/sft/checkpoints/latest.pt",
    "num_rollouts": 1,
    "max_new_tokens": 16,
    "temperature": 0.8,
    "top_k": 50,
    "top_p": 1.0,
    "distill_temperature": 2.0,
    "kl_weight": 1.0,
    "ce_weight": 0.1
  }
}
